<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #080808;
            --bg2: #0f0f0f;
            --bg3: #161616;
            --white: #f5f5f5;
            --white2: #d0d0d0;
            --muted: #888;
            --muted2: #555;
            --border: rgba(255, 255, 255, 0.07);
            --border2: rgba(255, 255, 255, 0.14);
            --silver: #c8c8c8;
            --radius: 8px;
            --font-display: 'Space Grotesk', sans-serif;
            --font-body: 'DM Sans', sans-serif;
            --font-mono: 'Space Mono', monospace;
        }

        body {
            background: var(--bg);
            color: var(--white);
            font-family: var(--font-body);
            font-size: 15px;
            line-height: 1.6;
            overflow-x: hidden;
        }

        .admin-layout { display: flex; min-height: 100vh; }

        .admin-sidebar {
            width: 240px;
            background: var(--bg2);
            border-right: 1px solid var(--border);
            padding: 24px 0;
            overflow-y: auto;
        }

        .admin-sidebar-header {
            padding: 0 24px 20px;
            border-bottom: 1px solid var(--border);
            margin-bottom: 24px;
        }

        .admin-sidebar-header .nav-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .admin-sidebar-header .logo-mark {
            width: 32px;
            height: 32px;
            background: var(--white);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-display);
            font-weight: 700;
            font-size: 12px;
            color: #000;
        }

        .admin-sidebar-header .logo-text {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 15px;
            color: var(--white);
        }

        .admin-sidebar-menu {
            list-style: none;
            padding: 0 12px;
        }

        .admin-sidebar-menu li { margin-bottom: 4px; }

        .admin-sidebar-menu li a {
            display: flex;
            align-items: center;
            padding: 10px 12px;
            text-decoration: none;
            color: var(--muted);
            font-size: 13.5px;
            border-radius: var(--radius);
            transition: all 0.2s;
            gap: 10px;
        }

        .admin-sidebar-menu li a:hover {
            background: rgba(255, 255, 255, 0.05);
            color: var(--white);
        }

        .admin-sidebar-menu li a.active {
            background: var(--white);
            color: #000;
            font-weight: 500;
        }

        .admin-main-content { flex: 1; padding: 32px 36px; min-width: 0; }

        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
            flex-wrap: wrap;
            gap: 16px;
        }

        .page-header h1 {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 1.6rem;
            color: var(--white);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .page-header h1 i { font-size: 20px; color: var(--silver); }

        .btn-secondary {
            background: transparent;
            color: var(--white);
            border: 1px solid var(--border2);
            padding: 10px 20px;
            border-radius: var(--radius);
            font-family: var(--font-display);
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.04);
            border-color: var(--border2);
        }

        .search-form {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .search-form input {
            flex: 1;
            background: var(--bg3);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 10px 14px;
            color: var(--white);
            font-family: var(--font-body);
            font-size: 14px;
            outline: none;
        }

        .search-form input:focus { border-color: var(--border2); }

        .table-container {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
        }

        table { width: 100%; border-collapse: collapse; }

        th, td {
            padding: 14px 20px;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        th {
            background: var(--bg3);
            font-family: var(--font-mono);
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--muted);
        }

        td { font-size: 13.5px; color: var(--white2); }

        tr:hover td { background: rgba(255, 255, 255, 0.02); }

        .pagination {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-top: 24px;
            padding: 20px;
        }

        .pagination a, .pagination span {
            padding: 8px 14px;
            border-radius: var(--radius);
            text-decoration: none;
            font-family: var(--font-mono);
            font-size: 12px;
            color: var(--muted);
            background: var(--bg3);
            border: 1px solid var(--border);
        }

        .pagination a:hover {
            background: rgba(255, 255, 255, 0.05);
            color: var(--white);
        }

        .pagination .active {
            background: var(--white);
            color: #000;
        }

        @media (max-width: 900px) {
            .admin-layout { flex-direction: column; }
            .admin-sidebar { width: 100%; height: auto; }
            .admin-main-content { padding: 20px; }
        }
    </style>
</head>
<body>
    <div class="admin-layout">
        <!-- SIDEBAR -->
        <aside class="admin-sidebar">
            <div class="admin-sidebar-header">
                <a href="/" class="nav-logo">
                    <div class="logo-mark">EC</div>
                    <span class="logo-text">E-Cell <span>GCOE</span></span>
                </a>
            </div>
            <ul class="admin-sidebar-menu">
                <li><a href="/admin/dashboard"><i class="ri-home-4-line"></i> Dashboard</a></li>
                <li><a href="/admin/events"><i class="ri-calendar-event-line"></i> Events</a></li>
                <li><a href="/admin/events" class="active"><i class="ri-file-list-3-line"></i> Registrations</a></li>
                <li><a href="#"><i class="ri-money-dollar-box-line"></i> Payments</a></li>
                <li><a href="/admin/events/<%= event._id %>/registrations/export"><i class="ri-file-download-line"></i> Export CSV</a></li>
                <li><a href="/admin/logout"><i class="ri-logout-box-line"></i> Logout</a></li>
            </ul>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="admin-main-content">
            <div class="page-header">
                <h1><i class="ri-file-list-3-line"></i> Registrations: <%= event.title %></h1>
                <a href="/admin/events/<%= event._id %>/registrations/export" class="btn-secondary">
                    <i class="ri-file-download-line"></i> Export CSV
                </a>
            </div>

            <form class="search-form" method="GET">
                <input type="text" name="search" placeholder="Search registrations..." value="<%= search %>">
            </form>

            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>College</th>
                            <th>Branch</th>
                            <th>Year</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (registrations && registrations.length > 0) { %>
                            <% registrations.forEach(reg => { %>
                                <tr>
                                    <td><%= reg.name %></td>
                                    <td><%= reg.email %></td>
                                    <td><%= reg.phone %></td>
                                    <td><%= reg.college || '—' %></td>
                                    <td><%= reg.branch || '—' %></td>
                                    <td><%= reg.year || '—' %></td>
                                    <td>₹<%= reg.amount %></td>
                                    <td>
                                        <span style="color: <%= reg.paymentStatus === 'paid' ? '#51cf66' : '#ff6b6b' %>;">
                                            <%= reg.paymentStatus %>
                                        </span>
                                    </td>
                                    <td><%= reg.registrationTime ? new Date(reg.registrationTime).toDateString() : '—' %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="9" style="text-align:center;padding:40px;color:var(--muted);">No registrations found</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <% if (totalPages > 1) { %>
                <div class="pagination">
                    <% if (page > 1) { %>
                        <a href="?page=<%= page - 1 %>&search=<%= search %>"><i class="ri-arrow-left-line"></i></a>
                    <% } %>

                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <% if (i === page) { %>
                            <span class="active"><%= i %></span>
                        <% } else { %>
                            <a href="?page=<%= i %>&search=<%= search %>"><%= i %></a>
                        <% } %>
                    <% } %>

                    <% if (page < totalPages) { %>
                        <a href="?page=<%= page + 1 %>&search=<%= search %>"><i class="ri-arrow-right-line"></i></a>
                    <% } %>
                </div>
            <% } %>
        </main>
    </div>
</body>
</html>