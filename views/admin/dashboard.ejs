<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard | E-Cell GCOE Kolhapur</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/locomotive-scroll@4.1.4/dist/locomotive-scroll.min.css" />

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:      #080808;
            --bg2:     #0f0f0f;
            --bg3:     #161616;
            --white:   #f5f5f5;
            --white2:  #d0d0d0;
            --muted:   #888;
            --muted2:  #555;
            --border:  rgba(255,255,255,0.07);
            --border2: rgba(255,255,255,0.14);
            --silver:  #c8c8c8;
            --radius:  8px;
            --font-display: 'Space Grotesk', sans-serif;
            --font-body:    'DM Sans', sans-serif;
            --font-mono:    'Space Mono', monospace;
        }

        html { scroll-behavior: smooth; }

        body {
            background: var(--bg);
            color: var(--white);
            font-body: var(--font-body);
            font-size: 16px;
            line-height: 1.7;
            overflow-x: hidden;
        }

        #scroll-container { overflow: hidden; }

        ::selection { background: rgba(255,255,255,0.15); }
        ::-webkit-scrollbar { width: 2px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: #444; border-radius: 2px; }

        /* ── ADMIN LAYOUT ── */
        .admin-layout {
            display: flex;
            min-height: 100vh;
        }

        /* ── SIDEBAR ── */
        .admin-sidebar {
            width: 260px;
            background: var(--bg2);
            border-right: 1px solid var(--border);
            padding: 20px 0;
            overflow-y: auto;
        }

        .admin-sidebar-header {
            padding: 0 24px 20px;
            border-bottom: 1px solid var(--border);
            margin-bottom: 24px;
        }

        .admin-sidebar-header .nav-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .admin-sidebar-header .logo-mark {
            width: 32px;
            height: 32px;
            background: var(--white);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-display);
            font-weight: 700;
            font-size: 12px;
            color: #000;
            letter-spacing: -0.5px;
        }

        .admin-sidebar-header .logo-text {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 15px;
            color: var(--white);
            letter-spacing: -0.3px;
        }

        .admin-sidebar-header .logo-text span {
            color: var(--muted);
        }

        .admin-sidebar-menu {
            list-style: none;
        }

        .admin-sidebar-menu li {
            margin-bottom: 8px;
        }

        .admin-sidebar-menu li a {
            display: flex;
            align-items: center;
            padding: 12px 24px;
            text-decoration: none;
            color: var(--muted);
            font-size: 13px;
            font-weight: 400;
            border-radius: var(--radius);
            transition: all 0.2s;
            gap: 10px;
        }

        .admin-sidebar-menu li a:hover {
            background: rgba(255,255,255,0.05);
            color: var(--white);
        }

        .admin-sidebar-menu li a.active {
            background: var(--white);
            color: #000;
            font-weight: 500;
        }

        .admin-sidebar-menu li a i {
            font-size: 16px;
            width: 20px;
            text-align: center;
        }

        /* ── MAIN CONTENT ── */
        .admin-main-content {
            flex: 1;
            padding: 30px;
            overflow-y: auto;
        }

        /* ── DASHBOARD CARDS ── */
        .dashboard-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .dashboard-card {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
            transition: all 0.2s;
        }

        .dashboard-card:hover {
            border-color: var(--border2);
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        }

        .dashboard-card .card-icon {
            width: 48px;
            height: 48px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border2);
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: var(--silver);
            margin-bottom: 16px;
        }

        .dashboard-card .card-number {
            font-family: var(--font-display);
            font-weight: 700;
            font-size: 2.5rem;
            color: var(--white);
            line-height: 1;
            margin-bottom: 8px;
            letter-spacing: -1px;
        }

        .dashboard-card .card-label {
            font-size: 13px;
            color: var(--muted);
            font-family: var(--font-display);
            font-weight: 500;
        }

        /* ── WELCOME SECTION ── */
        .welcome-section {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
            margin-bottom: 30px;
        }

        .welcome-section h2 {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 1.75rem;
            margin-bottom: 16px;
            color: var(--white);
        }

        .welcome-section p {
            color: var(--muted);
            line-height: 1.7;
            font-size: 15px;
            max-width: 600px;
        }

        /* ── RECENT ACTIVITY ── */
        .activity-section {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
        }

        .activity-section h2 {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 1.5rem;
            margin-bottom: 20px;
            color: var(--white);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .activity-section h2 i {
            font-size: 18px;
        }

        .activity-item {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-top: 1px solid var(--border);
        }

        .activity-item:first-child {
            border-top: none;
        }

        .activity-details {
            flex: 1;
        }

        .activity-details h3 {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 1.25rem;
            margin-bottom: 4px;
            color: var(--white2);
        }

        .activity-details p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

        .activity-time {
            font-family: var(--font-mono);
            font-size: 11px;
            color: var(--muted2);
        }

        /* ── RESPONSIVE ── */
        @media (max-width: 768px) {
            .admin-layout {
                flex-direction: column;
            }

            .admin-sidebar {
                width: 100%;
                height: auto;
                border-right: none;
                border-bottom: 1px solid var(--border);
            }

            .admin-main-content {
                padding: 20px;
            }

            .dashboard-cards {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 480px) {
            .dashboard-cards {
                grid-template-columns: 1fr;
            }

            .welcome-section h2 {
                font-size: 1.5rem;
            }

            .activity-section h2 {
                font-size: 1.25rem;
            }
        }
    </style>
</head>
<body>
    <div id="scroll-container" data-scroll-container>
        <div class="admin-layout">
            <!-- Sidebar -->
            <aside class="admin-sidebar">
                <div class="admin-sidebar-header">
                    <a href="#" class="nav-logo">
                        <div class="logo-mark">EC</div>
                        <span class="logo-text">E-Cell <span>GCOE</span></span>
                    </a>
                </div>

                <ul class="admin-sidebar-menu">
                    <li>
                        <a href="/admin/dashboard" class="active">
                            <i class="ri-home-4-line"></i> Dashboard
                        </a>
                    </li>
                    <li>
                        <a href="/admin/events">
                            <i class="ri-calendar-event-line"></i> Events
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="ri-file-list-3-line"></i> Registrations
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="ri-money-dollar-box-line"></i> Payments
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="ri-file-download-line"></i> Export CSV
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="ri-settings-3-line"></i> Settings
                        </a>
                    </li>
                    <li>
                        <a href="/admin/logout">
                            <i class="ri-logout-box-line"></i> Logout
                        </a>
                    </li>
                </ul>
            </aside>

            <!-- Main Content -->
            <main class="admin-main-content">
                <!-- Welcome Section -->
                <section class="welcome-section">
                    <h2>Welcome back, Admin!</h2>
                    <p>Here's an overview of your E-Cell events and activities. Manage events, view registrations, and track performance from this dashboard.</p>
                </section>

                <!-- Dashboard Cards -->
                <div class="dashboard-cards">
                    <div class="dashboard-card">
                        <div class="card-icon"><i class="ri-calendar-event-line"></i></div>
                        <div class="card-number"><%= totalEvents %></div>
                        <div class="card-label">Total Events</div>
                    </div>
                    <div class="dashboard-card">
                        <div class="card-icon"><i class="ri-sun-line"></i></div>
                        <div class="card-number"><%= upcomingCount %></div>
                        <div class="card-label">Upcoming Events</div>
                    </div>
                    <div class="dashboard-card">
                        <div class="card-icon"><i class="ri-record-circle-line"></i></div>
                        <div class="card-number"><%= liveCount %></div>
                        <div class="card-label">Live Events</div>
                    </div>
                    <div class="dashboard-card">
                        <div class="card-icon"><i class="ri-check-circle-line"></i></div>
                        <div class="card-number"><%= completedCount %></div>
                        <div class="card-label">Completed Events</div>
                    </div>
                    <div class="dashboard-card">
                        <div class="card-icon"><i class="ri-user-add-line"></i></div>
                        <div class="card-number"><%= totalRegistrations %></div>
                        <div class="card-label">Total Registrations</div>
                    </div>
                    <div class="dashboard-card">
                        <div class="card-icon"><i class="ri-money-dollar-box-line"></i></div>
                        <div class="card-number">₹<%= totalRevenue %></div>
                        <div class="card-label">Total Revenue</div>
                    </div>
                </div>

                <!-- Recent Activity Section -->
                <section class="activity-section">
                    <h2><i class="ri-time-line"></i> Recent Activity</h2>
                    <div class="activity-items">
                        <% if (recentRegistrations && recentRegistrations.length > 0) { %>
                            <% recentRegistrations.forEach(reg => { %>
                                <div class="activity-item">
                                    <div class="activity-details">
                                        <h3>Registration Received</h3>
                                        <p><%= reg.name %> registered for <%= reg.eventId ? reg.eventId.title : 'Event' %></p>
                                    </div>
                                    <div class="activity-time">
                                        <%= new Date(reg.registrationTime).toLocaleDateString() %>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="activity-item">
                                <div class="activity-details">
                                    <h3>No Recent Registrations</h3>
                                    <p>Registrations will appear here once students sign up for events.</p>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </section>
            </main>
        </div>
    </div>

    <!-- Locomotive Scroll -->
    <script src="https://cdn.jsdelivr.net/npm/locomotive-scroll@4.1.4/dist/locomotive-scroll.min.js"></script>

    <script>
        const locoScroll = new LocomotiveScroll({
            el: document.querySelector('#scroll-container'),
            smooth: true,
            multiplier: 0.9,
            lerp: 0.07,
            smartphone: { smooth: false },
            tablet:     { smooth: false }
        });

        // Update scroll on dynamic content changes
        window.addEventListener('load', () => { locoScroll.update(); });

        // Handle flash messages auto-hide
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(() => {
                const flashMessages = document.querySelectorAll('.flash-message');
                flashMessages.forEach(msg => {
                    msg.style.opacity = '0';
                    setTimeout(() => {
                        if (msg.parentElement) {
                            msg.parentElement.removeChild(msg);
                        }
                    }, 300);
                });
            }, 5000);
        });
    </script>
</body>
</html>
