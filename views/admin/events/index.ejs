<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= pageTitle %>
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=Space+Mono:wght@400;700&display=swap"
    rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/locomotive-scroll@4.1.4/dist/locomotive-scroll.min.css" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg: #080808;
      --bg2: #0f0f0f;
      --bg3: #161616;
      --bg4: #1e1e1e;
      --white: #f5f5f5;
      --white2: #d0d0d0;
      --muted: #888;
      --muted2: #555;
      --border: rgba(255, 255, 255, 0.07);
      --border2: rgba(255, 255, 255, 0.14);
      --silver: #c8c8c8;
      --radius: 8px;
      --font-display: 'Space Grotesk', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --font-mono: 'Space Mono', monospace;
    }

    html,
    body {
      height: 100%;
    }

    body {
      background: var(--bg);
      color: var(--white);
      font-family: var(--font-body);
      font-size: 15px;
      line-height: 1.6;
      overflow-x: hidden;
    }

    #scroll-container {
      overflow: hidden;
    }

    ::-webkit-scrollbar {
      width: 2px;
    }

    ::-webkit-scrollbar-track {
      background: var(--bg);
    }

    ::-webkit-scrollbar-thumb {
      background: #444;
    }

    /* ── LAYOUT ── */
    .admin-layout {
      display: flex;
      min-height: 100vh;
    }

    /* ── SIDEBAR ── */
    .admin-sidebar {
      width: 240px;
      flex-shrink: 0;
      background: var(--bg2);
      border-right: 1px solid var(--border);
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
    }

    .admin-sidebar-header {
      padding: 24px 24px 20px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 24px;
    }

    .admin-sidebar-header .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }

    .admin-sidebar-header .logo-mark {
      width: 32px;
      height: 32px;
      background: var(--white);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 12px;
      color: #000;
    }

    .admin-sidebar-header .logo-text {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 15px;
      color: var(--white);
    }

    .admin-sidebar-header .logo-text span {
      color: var(--muted);
    }

    .admin-sidebar-menu {
      list-style: none;
      padding: 0 12px;
      flex: 1;
    }

    .admin-sidebar-menu li {
      margin-bottom: 4px;
    }

    .admin-sidebar-menu li a {
      display: flex;
      align-items: center;
      padding: 10px 12px;
      text-decoration: none;
      color: var(--muted);
      font-size: 13.5px;
      border-radius: var(--radius);
      transition: all 0.2s;
      gap: 10px;
    }

    .admin-sidebar-menu li a:hover {
      background: rgba(255, 255, 255, 0.05);
      color: var(--white);
    }

    .admin-sidebar-menu li a.active {
      background: var(--white);
      color: #000;
      font-weight: 500;
    }

    .admin-sidebar-menu li a i {
      font-size: 16px;
      width: 20px;
      text-align: center;
      flex-shrink: 0;
    }

    .sidebar-divider {
      height: 1px;
      background: var(--border);
      margin: 12px 12px;
    }

    /* ── MAIN ── */
    .admin-main-content {
      flex: 1;
      padding: 32px 36px;
      min-width: 0;
    }

    /* ── PAGE HEADER ── */
    .page-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 28px;
      flex-wrap: wrap;
      gap: 16px;
    }

    .page-header h1 {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 1.6rem;
      color: var(--white);
      display: flex;
      align-items: center;
      gap: 10px;
      letter-spacing: -0.5px;
    }

    .page-header h1 i {
      font-size: 20px;
      color: var(--silver);
    }

    /* ── BUTTONS ── */
    .btn-primary {
      background: var(--white);
      color: #000;
      border: none;
      padding: 10px 20px;
      border-radius: var(--radius);
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: all 0.2s;
    }

    .btn-primary:hover {
      background: var(--white2);
      transform: translateY(-1px);
    }

    .btn-icon {
      width: 34px;
      height: 34px;
      border-radius: var(--radius);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      transition: all 0.2s;
      cursor: pointer;
      border: none;
      background: none;
    }

    .btn-icon:hover {
      transform: scale(1.08);
    }

    .btn-icon.edit {
      background: rgba(0, 123, 255, 0.1);
      color: #4dabff;
      border: 1px solid rgba(0, 123, 255, 0.2);
    }

    .btn-icon.edit:hover {
      background: rgba(0, 123, 255, 0.2);
    }

    .btn-icon.delete {
      background: rgba(255, 99, 71, 0.1);
      color: #ff6b6b;
      border: 1px solid rgba(255, 99, 71, 0.2);
    }

    .btn-icon.delete:hover {
      background: rgba(255, 99, 71, 0.2);
    }

    .btn-icon.publish {
      background: rgba(40, 167, 69, 0.1);
      color: #51cf66;
      border: 1px solid rgba(40, 167, 69, 0.2);
    }

    .btn-icon.publish:hover {
      background: rgba(40, 167, 69, 0.2);
    }

    .btn-icon.unpublish {
      background: rgba(255, 193, 7, 0.1);
      color: #ffc107;
      border: 1px solid rgba(255, 193, 7, 0.2);
    }

    .btn-icon.unpublish:hover {
      background: rgba(255, 193, 7, 0.2);
    }

    .btn-icon.form-pub {
      background: rgba(149, 97, 255, 0.1);
      color: #a78bfa;
      border: 1px solid rgba(149, 97, 255, 0.2);
    }

    .btn-icon.form-pub:hover {
      background: rgba(149, 97, 255, 0.2);
    }

    .btn-icon.registrations {
      background: rgba(20, 184, 166, 0.1);
      color: #2dd4bf;
      border: 1px solid rgba(20, 184, 166, 0.2);
    }

    .btn-icon.registrations:hover {
      background: rgba(20, 184, 166, 0.2);
    }

    /* ── FLASH ── */
    .flash-messages {
      margin-bottom: 20px;
    }

    .flash-message {
      padding: 12px 16px;
      border-radius: var(--radius);
      margin-bottom: 10px;
      font-size: 13.5px;
      font-family: var(--font-display);
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .flash-message.error {
      background: rgba(255, 0, 0, 0.08);
      border: 1px solid rgba(255, 0, 0, 0.2);
      color: #ff6b6b;
    }

    .flash-message.success {
      background: rgba(40, 167, 69, 0.08);
      border: 1px solid rgba(40, 167, 69, 0.2);
      color: #51cf66;
    }

    /* ── TABLE CONTAINER ── */
    .events-container {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
    }

    .events-header {
      padding: 18px 24px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .events-header h2 {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 1.1rem;
      color: var(--white);
      margin: 0;
    }

    .events-count {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--muted);
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 3px 10px;
    }

    /* ── TABLE ── */
    .events-table {
      width: 100%;
      border-collapse: collapse;
    }

    .events-table th,
    .events-table td {
      padding: 14px 20px;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }

    .events-table th {
      background: var(--bg3);
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--muted);
    }

    .events-table td {
      font-size: 13.5px;
      color: var(--white2);
      vertical-align: middle;
    }

    .events-table tr:hover td {
      background: rgba(255, 255, 255, 0.02);
    }

    .events-table tr:last-child td {
      border-bottom: none;
    }

    .event-title {
      font-weight: 500;
      color: var(--white);
      font-family: var(--font-display);
      margin-bottom: 2px;
      font-size: 14px;
    }

    .event-venue {
      font-size: 11.5px;
      color: var(--muted);
      margin-top: 2px;
    }

    /* ── STATUS BADGES ── */
    .status-badge {
      padding: 3px 9px;
      border-radius: 20px;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      font-family: var(--font-mono);
      display: inline-block;
    }

    .status-badge.draft {
      background: rgba(128, 128, 128, 0.15);
      color: var(--white2);
      border: 1px solid rgba(128, 128, 128, 0.25);
    }

    .status-badge.upcoming {
      background: rgba(0, 123, 255, 0.15);
      color: #4dabff;
      border: 1px solid rgba(0, 123, 255, 0.25);
    }

    .status-badge.live {
      background: rgba(255, 99, 71, 0.15);
      color: #ff6b6b;
      border: 1px solid rgba(255, 99, 71, 0.25);
    }

    .status-badge.completed {
      background: rgba(40, 167, 69, 0.15);
      color: #51cf66;
      border: 1px solid rgba(40, 167, 69, 0.25);
    }

    /* ── PUBLISH BADGES — fixed as column stack ── */
    .publish-stack {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .publish-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 11px;
      font-family: var(--font-mono);
      white-space: nowrap;
    }

    .publish-badge.yes i {
      color: #51cf66;
      font-size: 13px;
    }

    .publish-badge.no i {
      color: var(--muted2);
      font-size: 13px;
    }

    .publish-badge.yes span {
      color: var(--white2);
    }

    .publish-badge.no span {
      color: var(--muted2);
    }

    /* ── ACTIONS ── */
    .action-buttons {
      display: flex;
      align-items: center;
      gap: 6px;
      flex-wrap: nowrap;
    }

    .action-buttons form {
      display: inline;
      margin: 0;
    }

    /* ── EMPTY STATE ── */
    .empty-state {
      text-align: center;
      padding: 60px 24px;
    }

    .empty-state i {
      font-size: 52px;
      color: var(--muted2);
      margin-bottom: 16px;
      display: block;
    }

    .empty-state h3 {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 1.3rem;
      margin-bottom: 10px;
      color: var(--white);
    }

    .empty-state p {
      font-size: 13.5px;
      color: var(--muted);
      max-width: 380px;
      margin: 0 auto 20px;
      line-height: 1.7;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .admin-layout {
        flex-direction: column;
      }

      .admin-sidebar {
        width: 100%;
        height: auto;
        position: relative;
      }

      .admin-main-content {
        padding: 20px;
      }
    }

    @media (max-width: 600px) {
      .events-table {
        display: block;
        overflow-x: auto;
      }
    }
  </style>
</head>

<body>
  <div id="scroll-container" data-scroll-container>
    <div class="admin-layout">

      <!-- SIDEBAR -->
      <aside class="admin-sidebar">
        <div class="admin-sidebar-header">
          <a href="/" class="nav-logo">
            <div class="logo-mark">EC</div>
            <span class="logo-text">E-Cell <span>GCOE</span></span>
          </a>
        </div>
        <ul class="admin-sidebar-menu">
          <li><a href="/admin/dashboard"><i class="ri-home-4-line"></i> Dashboard</a></li>
          <li><a href="/admin/events" class="active"><i class="ri-calendar-event-line"></i> Events</a></li>
          <li><a href="#"><i class="ri-file-list-3-line"></i> Registrations</a></li>
          <li><a href="#"><i class="ri-money-dollar-box-line"></i> Payments</a></li>
          <div class="sidebar-divider"></div>
          <li><a href="#"><i class="ri-settings-3-line"></i> Settings</a></li>
          <li><a href="/admin/logout"><i class="ri-logout-box-line"></i> Logout</a></li>
        </ul>
      </aside>

      <!-- MAIN CONTENT -->
      <main class="admin-main-content">

        <!-- Flash Messages -->
        <% if (successMsg && successMsg.length> 0) { %>
          <div class="flash-messages">
            <% (Array.isArray(successMsg) ? successMsg : [successMsg]).forEach(msg=> { %>
              <div class="flash-message success"><i class="ri-checkbox-circle-line"></i>
                <%= msg %>
              </div>
              <% }) %>
          </div>
          <% } %>
            <% if (errorMsg && errorMsg.length> 0) { %>
              <div class="flash-messages">
                <% (Array.isArray(errorMsg) ? errorMsg : [errorMsg]).forEach(msg=> { %>
                  <div class="flash-message error"><i class="ri-error-warning-line"></i>
                    <%= msg %>
                  </div>
                  <% }) %>
              </div>
              <% } %>

                <!-- Page Header -->
                <div class="page-header">
                  <h1><i class="ri-calendar-event-line"></i> Manage Events</h1>
                  <a href="/admin/events/create" class="btn-primary">
                    <i class="ri-add-line"></i> Create New Event
                  </a>
                </div>

                <!-- Events Table -->
                <div class="events-container">
                  <% if (events && events.length> 0) { %>
                    <div class="events-header">
                      <h2>All Events</h2>
                      <span class="events-count">
                        <%= events.length %> event<%= events.length !==1 ? 's' : '' %>
                      </span>
                    </div>

                    <table class="events-table">
                      <thead>
                        <tr>
                          <th>Event</th>
                          <th>Date / Time</th>
                          <th>Status</th>
                          <th>Published</th>
                          <th>Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% events.forEach(event=> { %>
                          <tr>
                            <!-- Title + Venue -->
                            <td>
                              <div class="event-title">
                                <%= event.title %>
                              </div>
                              <div class="event-venue"><i class="ri-map-pin-line"
                                  style="font-size:11px;margin-right:3px;"></i>
                                <%= event.venue || '—' %>
                              </div>
                            </td>

                            <!-- Date + Time -->
                            <td>
                              <div style="font-weight:500;color:var(--white);font-size:13px;">
                                <%= event.eventDate ? new Date(event.eventDate).toDateString() : event.date %>
                              </div>
                              <div style="font-size:11.5px;color:var(--muted);margin-top:2px;">
                                <%= event.time || '—' %>
                              </div>
                            </td>

                            <!-- Status badge -->
                            <td>
                              <span class="status-badge <%= event.status %>">
                                <%= event.status.charAt(0).toUpperCase() + event.status.slice(1) %>
                              </span>
                            </td>

                            <!-- Published — stacked badges (FIXED) -->
                            <td>
                              <div class="publish-stack">
                                <div class="publish-badge <%= event.eventPublished ? 'yes' : 'no' %>">
                                  <i
                                    class="<%= event.eventPublished ? 'ri-checkbox-circle-fill' : 'ri-checkbox-blank-circle-line' %>"></i>
                                  <span>Event</span>
                                </div>
                                <div class="publish-badge <%= event.formPublished ? 'yes' : 'no' %>">
                                  <i
                                    class="<%= event.formPublished ? 'ri-checkbox-circle-fill' : 'ri-checkbox-blank-circle-line' %>"></i>
                                  <span>Form</span>
                                </div>
                              </div>
                            </td>

                            <!-- Actions -->
                            <td>
                              <div class="action-buttons">
                                <!-- Edit -->
                                <a href="/admin/events/edit/<%= event._id %>" class="btn-icon edit" title="Edit Event">
                                  <i class="ri-pencil-line"></i>
                                </a>

                                <!-- Publish / Unpublish EVENT -->
                                <% if (event.eventPublished) { %>
                                  <form action="/admin/events/unpublish/<%= event._id %>" method="POST">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button type="submit" class="btn-icon unpublish" title="Unpublish Event"
                                      onclick="return confirm('Unpublish this event? Students will no longer see it.');">
                                      <i class="ri-eye-off-line"></i>
                                    </button>
                                  </form>
                                  <% } else { %>
                                    <form action="/admin/events/publish/<%= event._id %>" method="POST">
                                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                      <button type="submit" class="btn-icon publish" title="Publish Event"
                                        onclick="return confirm('Publish this event? Students will see it.');">
                                        <i class="ri-eye-line"></i>
                                      </button>
                                    </form>
                                    <% } %>

                                      <!-- Publish / Unpublish FORM (only if event is published) -->
                                      <% if (event.eventPublished) { %>
                                        <% if (event.formPublished) { %>
                                          <form action="/admin/events/unpublish-form/<%= event._id %>" method="POST">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit" class="btn-icon unpublish"
                                              title="Close Registration Form"
                                              onclick="return confirm('Close the registration form?');">
                                              <i class="ri-lock-line"></i>
                                            </button>
                                          </form>
                                          <% } else { %>
                                            <form action="/admin/events/publish-form/<%= event._id %>" method="POST">
                                              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                              <button type="submit" class="btn-icon form-pub"
                                                title="Open Registration Form"
                                                onclick="return confirm('Open the registration form? Apply Now button will appear.');">
                                                <i class="ri-lock-unlock-line"></i>
                                              </button>
                                            </form>
                                            <% } %>
                                              <% } %>

                                                <!-- Registrations -->
                                                <a href="/admin/events/<%= event._id %>/registrations"
                                                  class="btn-icon registrations" title="View Registrations">
                                                  <i class="ri-group-line"></i>
                                                </a>

                                                <!-- Delete -->
                                                <form action="/admin/events/delete/<%= event._id %>" method="POST">
                                                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                  <button type="submit" class="btn-icon delete" title="Delete Event"
                                                    onclick="return confirm('Delete this event permanently? This cannot be undone.');">
                                                    <i class="ri-delete-bin-line"></i>
                                                  </button>
                                                </form>
                              </div>
                            </td>
                          </tr>
                          <% }) %>
                      </tbody>
                    </table>

                    <% } else { %>
                      <div class="empty-state">
                        <i class="ri-calendar-2-line"></i>
                        <h3>No Events Yet</h3>
                        <p>You haven't created any events yet. Click the button above to create your first event.</p>
                        <a href="/admin/events/create" class="btn-primary"><i class="ri-add-line"></i> Create First
                          Event</a>
                      </div>
                      <% } %>
                </div>

      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/locomotive-scroll@4.1.4/dist/locomotive-scroll.min.js"></script>
  <script>
    const locoScroll = new LocomotiveScroll({
      el: document.querySelector('#scroll-container'),
      smooth: true, multiplier: 0.9, lerp: 0.07,
      smartphone: { smooth: false }, tablet: { smooth: false }
    });
    window.addEventListener('load', () => locoScroll.update());

    // Auto-hide flash messages
    setTimeout(() => {
      document.querySelectorAll('.flash-message').forEach(el => {
        el.style.transition = 'opacity 0.4s';
        el.style.opacity = '0';
        setTimeout(() => el.remove(), 400);
      });
    }, 4000);
  </script>
</body>

</html>