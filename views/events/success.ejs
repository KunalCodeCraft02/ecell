<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/locomotive-scroll@4.1.4/dist/locomotive-scroll.min.css">

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #080808;
            --bg2: #0f0f0f;
            --bg3: #161616;
            --white: #f5f5f5;
            --white2: #d0d0d0;
            --muted: #888;
            --muted2: #555;
            --border: rgba(255, 255, 255, 0.07);
            --border2: rgba(255, 255, 255, 0.14);
            --silver: #c8c8c8;
            --radius: 8px;
            --font-display: 'Space Grotesk', sans-serif;
            --font-body: 'DM Sans', sans-serif;
            --font-mono: 'Space Mono', monospace;
        }

        html { scroll-behavior: smooth; }

        body {
            background: var(--bg);
            color: var(--white);
            font-family: var(--font-body);
            font-size: 16px;
            line-height: 1.7;
            overflow-x: hidden;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        #scroll-container { overflow: hidden; }

        ::selection { background: rgba(255, 255, 255, 0.15); }
        ::-webkit-scrollbar { width: 2px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: #444; border-radius: 2px; }

        .success-container {
            padding: 60px 5%;
            max-width: 600px;
            margin: 0 auto;
            text-align: center;
        }

        .success-icon {
            width: 100px;
            height: 100px;
            background: rgba(40, 167, 69, 0.15);
            border: 2px solid rgba(40, 167, 69, 0.3);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
        }

        .success-icon i {
            font-size: 48px;
            color: #51cf66;
        }

        .success-title {
            font-family: var(--font-display);
            font-weight: 700;
            font-size: 2rem;
            color: var(--white);
            margin-bottom: 12px;
        }

        .success-message {
            color: var(--muted);
            font-size: 15px;
            margin-bottom: 32px;
            line-height: 1.7;
        }

        .success-card {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 28px;
            text-align: left;
            margin-bottom: 24px;
        }

        .success-card h3 {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 1.2rem;
            color: var(--white);
            margin-bottom: 16px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
        }

        .info-row:last-child { border-bottom: none; }

        .info-label { color: var(--muted); }

        .info-value { color: var(--white); font-weight: 500; }

        .btn-primary {
            background: var(--white);
            color: #000;
            border: none;
            padding: 12px 24px;
            border-radius: var(--radius);
            font-family: var(--font-display);
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }

        .btn-primary:hover {
            background: var(--white2);
            transform: translateY(-1px);
        }
    </style>
</head>
<body>
    <div id="scroll-container" data-scroll-container>
        <div class="success-container" data-scroll-section>
            <div class="success-icon">
                <i class="ri-check-line"></i>
            </div>

            <h1 class="success-title">Registration Successful!</h1>
            <p class="success-message">
                You have successfully registered for <%= registration.eventId.title %>.
                Your payment of ₹<%= registration.amount %> has been confirmed.
            </p>

            <div class="success-card">
                <h3>Registration Details</h3>
                <div class="info-row">
                    <span class="info-label">Event</span>
                    <span class="info-value"><%= registration.eventId.title %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Name</span>
                    <span class="info-value"><%= registration.name %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Email</span>
                    <span class="info-value"><%= registration.email %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Payment Status</span>
                    <span class="info-value"><%= registration.paymentStatus %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Payment ID</span>
                    <span class="info-value"><%= registration.paymentId %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Registration Time</span>
                    <span class="info-value"><%= new Date(registration.registrationTime).toDateString() %></span>
                </div>
            </div>

            <a href="/events/upcoming" class="btn-primary">
                <i class="ri-calendar-event-line"></i> View Other Events
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/locomotive-scroll@4.1.4/dist/locomotive-scroll.min.js"></script>
    <script>
        const locoScroll = new LocomotiveScroll({
            el: document.querySelector('#scroll-container'),
            smooth: true, multiplier: 0.9, lerp: 0.07,
            smartphone: { smooth: false }, tablet: { smooth: false }
        });
    </script>
</body>
</html>