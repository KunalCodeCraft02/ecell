<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/locomotive-scroll@4.1.4/dist/locomotive-scroll.min.css">

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #080808;
            --bg2: #0f0f0f;
            --bg3: #161616;
            --bg4: #1e1e1e;
            --white: #f5f5f5;
            --white2: #d0d0d0;
            --muted: #888;
            --muted2: #555;
            --border: rgba(255, 255, 255, 0.07);
            --border2: rgba(255, 255, 255, 0.14);
            --silver: #c8c8c8;
            --radius: 8px;
            --font-display: 'Space Grotesk', sans-serif;
            --font-body: 'DM Sans', sans-serif;
            --font-mono: 'Space Mono', monospace;
        }

        html { scroll-behavior: smooth; }

        body {
            background: var(--bg);
            color: var(--white);
            font-family: var(--font-body);
            font-size: 16px;
            line-height: 1.7;
            overflow-x: hidden;
        }

        #scroll-container { overflow: hidden; min-height: 100vh; }

        ::selection { background: rgba(255, 255, 255, 0.15); }
        ::-webkit-scrollbar { width: 2px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: #444; border-radius: 2px; }

        /* ── NAV ── */
        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 0 5%;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(8, 8, 8, 0.55);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            transition: all 0.3s;
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .logo-mark {
            width: 32px;
            height: 32px;
            background: var(--white);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-display);
            font-weight: 700;
            font-size: 12px;
            color: #000;
        }

        .logo-text {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 15px;
            color: var(--white);
        }

        .logo-text span { color: var(--muted); }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 2px;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--muted);
            font-size: 13px;
            font-weight: 400;
            padding: 6px 13px;
            border-radius: 6px;
            transition: all 0.2s;
        }

        .nav-links a:hover {
            color: var(--white);
            background: rgba(255, 255, 255, 0.05);
        }

        .nav-cta {
            background: var(--white) !important;
            color: #000 !important;
            font-weight: 600 !important;
            padding: 7px 18px !important;
            border-radius: 6px !important;
        }

        .nav-hamburger {
            display: none;
            cursor: pointer;
            color: var(--white);
            font-size: 22px;
        }

        /* ── HERO ── */
        .event-hero {
            padding: 120px 5% 60px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .event-hero h1 {
            font-family: var(--font-display);
            font-weight: 700;
            font-size: clamp(2.4rem, 4vw, 3.2rem);
            letter-spacing: -2px;
            color: var(--white);
            margin-bottom: 20px;
        }

        .event-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            margin-bottom: 24px;
        }

        .event-meta-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: var(--font-mono);
            font-size: 12px;
            color: var(--muted);
        }

        .event-meta-item i { color: var(--silver); }

        .status-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            font-family: var(--font-mono);
            margin-left: auto;
        }

        .status-badge.upcoming {
            background: rgba(0, 123, 255, 0.15);
            color: #4dabff;
            border: 1px solid rgba(0, 123, 255, 0.25);
        }

        .status-badge.live {
            background: rgba(255, 99, 71, 0.15);
            color: #ff6b6b;
            border: 1px solid rgba(255, 99, 71, 0.25);
        }

        .status-badge.completed {
            background: rgba(40, 167, 69, 0.15);
            color: #51cf66;
            border: 1px solid rgba(40, 167, 69, 0.25);
        }

        .event-image-main {
            width: 100%;
            height: 400px;
            border-radius: 14px;
            overflow: hidden;
            margin-bottom: 40px;
            background: var(--bg2);
            border: 1px solid var(--border);
        }

        .event-image-main img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .event-content {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 40px;
        }

        .event-description {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 32px;
        }

        .section-title {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 1.2rem;
            color: var(--white);
            margin-bottom: 16px;
        }

        .event-description p {
            color: var(--muted);
            line-height: 1.8;
            margin-bottom: 16px;
        }

        .event-sidebar {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .info-card {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 24px;
        }

        .info-card h3 {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 1rem;
            color: var(--white);
            margin-bottom: 16px;
        }

        .info-item {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
        }

        .info-item:last-child { border-bottom: none; }

        .info-label { color: var(--muted); }

        .info-value { color: var(--white); font-weight: 500; }

        .btn-register {
            background: var(--white);
            color: #000;
            border: none;
            padding: 14px 24px;
            border-radius: var(--radius);
            font-family: var(--font-display);
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            justify-content: center;
            transition: all 0.2s;
        }

        .btn-register:hover {
            background: var(--white2);
            transform: translateY(-2px);
        }

        .btn-disabled {
            background: rgba(255, 255, 255, 0.05);
            color: var(--muted);
            border: 1px solid var(--border);
            cursor: not-allowed;
        }

        .btn-disabled:hover {
            transform: none;
            background: rgba(255, 255, 255, 0.05);
        }

        /* ── RESPONSIVE ── */
        @media (max-width: 768px) {
            .event-content { grid-template-columns: 1fr; }
            .nav-hamburger { display: block; }
            .nav-links { display: none; }
            .nav-links.open { display: flex; flex-direction: column; position: fixed; top: 64px; left: 0; right: 0; background: rgba(8, 8, 8, 0.99); padding: 28px 6%; border-bottom: 1px solid var(--border); }
        }
    </style>
</head>
<body>
    <div id="scroll-container" data-scroll-container>

        <!-- NAV -->
        <nav id="navbar">
            <a href="/" class="nav-logo">
                <div class="logo-mark">EC</div>
                <span class="logo-text">E-Cell <span>GCOE</span></span>
            </a>
            <ul class="nav-links" id="navLinks">
                <li><a href="/">Home</a></li>
                <li><a href="/#about">About</a></li>
                <li><a href="/#gallery">Gallery</a></li>
                <li><a href="/team">Team</a></li>
                <li><a href="/events/upcoming">Upcoming Events</a></li>
                <li><a href="/events/live">Live Events</a></li>
                <li><a href="/events/completed">Completed Events</a></li>
                <li><a href="/#contact" class="nav-cta">Contact</a></li>
            </ul>
            <button class="nav-hamburger" id="hamburgerBtn"><i class="ri-menu-3-line"></i></button>
        </nav>

        <!-- HERO -->
        <section class="event-hero" data-scroll-section>
            <h1><%= event.title %></h1>

            <div class="event-meta">
                <span class="event-meta-item">
                    <i class="ri-calendar-event-line"></i>
                    <%= event.eventDate ? new Date(event.eventDate).toDateString() %>
                </span>
                <% if (event.time) { %>
                    <span class="event-meta-item">
                        <i class="ri-time-line"></i>
                        <%= event.time %>
                    </span>
                <% } %>
                <% if (event.venue) { %>
                    <span class="event-meta-item">
                        <i class="ri-map-pin-line"></i>
                        <%= event.venue %>
                    </span>
                <% } %>
                <span class="status-badge <%= event.status %>"><%= event.status %></span>
            </div>

            <% if (event.image) { %>
                <div class="event-image-main">
                    <img src="<%= event.image %>" alt="<%= event.title %>">
                </div>
            <% } %>

            <div class="event-content">
                <div class="event-description">
                    <h2 class="section-title">About This Event</h2>
                    <p><%= event.description %></p>
                </div>

                <div class="event-sidebar">
                    <div class="info-card">
                        <h3>Event Details</h3>
                        <div class="info-item">
                            <span class="info-label">Fee</span>
                            <span class="info-value">₹<%= event.fee %></span>
                        </div>
                        <% if (event.maxParticipants > 0) { %>
                            <div class="info-item">
                                <span class="info-label">Max Participants</span>
                                <span class="info-value"><%= event.maxParticipants %></span>
                            </div>
                        <% } %>
                        <div class="info-item">
                            <span class="info-label">Status</span>
                            <span class="info-value"><%= event.status %></span>
                        </div>
                    </div>

                    <div class="info-card">
                        <% if (event.formPublished) { %>
                            <a href="/register/<%= event._id %>" class="btn-register">
                                <i class="ri-user-add-line"></i> Apply Now
                            </a>
                        <% } else if (event.eventPublished) { %>
                            <button class="btn-register btn-disabled" disabled>
                                <i class="ri-time-line"></i> Registration Opening Soon
                            </button>
                        <% } else { %>
                            <button class="btn-register btn-disabled" disabled>
                                <i class="ri-eye-off-line"></i> Event Not Published
                            </button>
                        <% } %>
                    </div>
                </div>
            </div>
        </section>

        <!-- FOOTER -->
        <footer style="background:var(--bg);border-top:1px solid var(--border);padding:40px 5%;text-align:center;">
            <p style="color:var(--muted);font-family:var(--font-mono);font-size:12px;">
                © <%= new Date().getFullYear() %> E-Cell GCOE Kolhapur
            </p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/locomotive-scroll@4.1.4/dist/locomotive-scroll.min.js"></script>
    <script>
        const locoScroll = new LocomotiveScroll({
            el: document.querySelector('#scroll-container'),
            smooth: true, multiplier: 0.9, lerp: 0.07,
            smartphone: { smooth: false }, tablet: { smooth: false }
        });
        window.addEventListener('load', () => locoScroll.update());

        // Hamburger menu
        const hamburger = document.getElementById('hamburgerBtn');
        const navLinks = document.getElementById('navLinks');
        if (hamburger) {
            hamburger.addEventListener('click', () => {
                navLinks.classList.toggle('open');
            });
        }
    </script>
</body>
</html>