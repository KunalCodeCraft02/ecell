<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/locomotive-scroll@4.1.4/dist/locomotive-scroll.min.css">

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #080808;
            --bg2: #0f0f0f;
            --bg3: #161616;
            --white: #f5f5f5;
            --white2: #d0d0d0;
            --muted: #888;
            --muted2: #555;
            --border: rgba(255, 255, 255, 0.07);
            --border2: rgba(255, 255, 255, 0.14);
            --silver: #c8c8c8;
            --radius: 8px;
            --font-display: 'Space Grotesk', sans-serif;
            --font-body: 'DM Sans', sans-serif;
            --font-mono: 'Space Mono', monospace;
        }

        html { scroll-behavior: smooth; }

        body {
            background: var(--bg);
            color: var(--white);
            font-family: var(--font-body);
            font-size: 16px;
            line-height: 1.7;
            overflow-x: hidden;
        }

        #scroll-container { overflow: hidden; }

        ::selection { background: rgba(255, 255, 255, 0.15); }
        ::-webkit-scrollbar { width: 2px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: #444; border-radius: 2px; }

        /* ── NAV ── */
        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 0 5%;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(8, 8, 8, 0.55);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            transition: all 0.3s;
        }

        nav.scrolled {
            background: rgba(8, 8, 8, 0.96);
            border-bottom-color: rgba(255, 255, 255, 0.1);
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .logo-mark {
            width: 32px;
            height: 32px;
            background: var(--white);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-display);
            font-weight: 700;
            font-size: 12px;
            color: #000;
            letter-spacing: -0.5px;
        }

        .logo-text {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 15px;
            color: var(--white);
            letter-spacing: -0.3px;
        }

        .logo-text span { color: var(--muted); }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 2px;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--muted);
            font-size: 13px;
            font-weight: 400;
            letter-spacing: 0.1px;
            padding: 6px 13px;
            border-radius: 6px;
            transition: all 0.2s;
        }

        .nav-links a:hover {
            color: var(--white);
            background: rgba(255, 255, 255, 0.05);
        }

        .nav-links a.active { color: var(--white); }

        .nav-cta {
            background: var(--white) !important;
            color: #000 !important;
            font-weight: 600 !important;
            font-size: 12.5px !important;
            padding: 7px 18px !important;
            border-radius: 6px !important;
        }

        .nav-hamburger {
            display: none;
            cursor: pointer;
            color: var(--white);
            font-size: 22px;
        }

        /* ── HERO ── */
        .hero {
            padding: 120px 5% 60px;
            text-align: center;
        }

        .hero h1 {
            font-family: var(--font-display);
            font-weight: 700;
            font-size: clamp(2.4rem, 4vw, 3.2rem);
            letter-spacing: -2px;
            color: var(--white);
            margin-bottom: 20px;
        }

        .hero p {
            color: var(--muted);
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto;
        }

        /* ── EVENTS GRID ── */
        .events-section {
            padding: 60px 5%;
            max-width: 1240px;
            margin: 0 auto;
        }

        .events-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 20px;
            margin-top: 40px;
        }

        .event-card {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: 14px;
            overflow: hidden;
            transition: all 0.28s;
            cursor: pointer;
            display: flex;
            flex-direction: column;
        }

        .event-card:hover {
            border-color: var(--border2);
            transform: translateY(-5px);
            box-shadow: 0 24px 64px rgba(0, 0, 0, 0.7);
        }

        .event-thumb {
            height: 220px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            background: var(--bg3);
            flex-shrink: 0;
        }

        .event-thumb-icon {
            font-size: 64px;
            color: rgba(255, 255, 255, 0.15);
        }

        .event-body {
            padding: 22px 22px 14px;
            flex: 1;
        }

        .event-date {
            font-family: var(--font-mono);
            font-size: 10px;
            color: var(--muted);
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .event-name {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 1.05rem;
            margin-bottom: 10px;
            letter-spacing: -0.2px;
            line-height: 1.3;
        }

        .event-desc {
            font-size: 13px;
            color: var(--muted);
            line-height: 1.72;
            font-weight: 300;
        }

        .event-footer {
            padding: 14px 22px;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .event-footer-info {
            font-size: 11px;
            color: var(--muted);
            display: flex;
            align-items: center;
            gap: 6px;
            font-family: var(--font-mono);
        }

        .event-arrow {
            color: var(--muted);
            font-size: 16px;
            transition: transform 0.2s, color 0.2s;
        }

        .event-card:hover .event-arrow {
            transform: translateX(4px);
            color: var(--white);
        }

        .status-badge.completed {
            background: rgba(40, 167, 69, 0.15);
            color: #51cf66;
            border: 1px solid rgba(40, 167, 69, 0.25);
            padding: 3px 9px;
            border-radius: 20px;
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            font-family: var(--font-mono);
        }

        .tag-completed {
            position: absolute;
            top: 12px;
            right: 12px;
            background: rgba(40, 167, 69, 0.15);
            color: #51cf66;
            border: 1px solid rgba(40, 167, 69, 0.25);
            padding: 4px 9px;
            border-radius: 4px;
            font-family: var(--font-mono);
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        /* ── EMPTY STATE ── */
        .empty-state {
            text-align: center;
            padding: 80px 20px;
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: 14px;
            grid-column: 1 / -1;
        }

        .empty-state i {
            font-size: 48px;
            color: var(--muted2);
            margin-bottom: 16px;
        }

        .empty-state h3 {
            font-family: var(--font-display);
            font-weight: 600;
            font-size: 1.3rem;
            color: var(--white);
            margin-bottom: 10px;
        }

        .empty-state p {
            color: var(--muted);
            font-size: 14px;
        }

        /* ── RESPONSIVE ── */
        @media (max-width: 768px) {
            .hero { padding: 100px 5% 40px; }
            .events-grid { grid-template-columns: 1fr; }
        }

        @media (max-width: 640px) {
            .nav-hamburger { display: block; }
            .nav-links { display: none; }
            .hero h1 { font-size: 2.2rem; }
        }
    </style>
</head>
<body>
    <div id="scroll-container" data-scroll-container>

        <!-- NAV -->
        <nav id="navbar">
            <a href="/" class="nav-logo">
                <div class="logo-mark">EC</div>
                <span class="logo-text">E-Cell <span>GCOE</span></span>
            </a>
            <ul class="nav-links" id="navLinks">
                <li><a href="/">Home</a></li>
                <li><a href="/#about">About</a></li>
                <li><a href="/#gallery">Gallery</a></li>
                <li><a href="/team">Team</a></li>
                <li><a href="/events/upcoming">Upcoming Events</a></li>
                <li><a href="/events/live">Live Events</a></li>
                <li><a href="/events/completed" class="active">Completed Events</a></li>
                <li><a href="/#contact" class="nav-cta">Contact</a></li>
            </ul>
            <button class="nav-hamburger" id="hamburgerBtn"><i class="ri-menu-3-line"></i></button>
        </nav>

        <!-- HERO -->
        <section class="hero" data-scroll-section>
            <h1>Completed Events</h1>
            <p>Events that have already taken place - view highlights and outcomes.</p>
        </section>

        <!-- EVENTS GRID -->
        <section class="events-section" data-scroll-section>
            <div class="events-grid">
                <% if (events && events.length > 0) { %>
                    <% events.forEach(event => { %>
                        <a href="/events/<%= event._id %>" class="event-card text-decoration-none">
                            <div class="event-thumb">
                                <% if (event.image) { %>
                                    <img src="<%= event.image %>" alt="<%= event.title %>" style="width:100%;height:100%;object-fit:cover;">
                                <% } else { %>
                                    <i class="event-thumb-icon ri-check-circle-line"></i>
                                <% } %>
                                <span class="tag-completed">Completed</span>
                            </div>
                            <div class="event-body">
                                <div class="event-date">
                                    <i class="ri-calendar-event-line"></i>
                                    <%= event.eventDate ? new Date(event.eventDate).toDateString() : '—' %>
                                </div>
                                <h3 class="event-name"><%= event.title %></h3>
                                <p class="event-desc"><%= event.description.substring(0, 120) %>...</p>
                            </div>
                            <div class="event-footer">
                                <span class="event-footer-info">
                                    <i class="ri-map-pin-line"></i>
                                    <%= event.venue || 'Online' %>
                                </span>
                                <i class="event-arrow ri-arrow-right-line"></i>
                            </div>
                        </a>
                    <% }) %>
                <% } else { %>
                    <div class="empty-state">
                        <i class="ri-history-line"></i>
                        <h3>No Completed Events Yet</h3>
                        <p>Events will appear here after they are marked as completed.</p>
                    </div>
                <% } %>
            </div>
        </section>

        <!-- FOOTER -->
        <footer style="background:var(--bg);border-top:1px solid var(--border);padding:40px 5%;text-align:center;">
            <p style="color:var(--muted);font-family:var(--font-mono);font-size:12px;">
                © <%= new Date().getFullYear() %> E-Cell GCOE Kolhapur
            </p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/locomotive-scroll@4.1.4/dist/locomotive-scroll.min.js"></script>
    <script>
        const locoScroll = new LocomotiveScroll({
            el: document.querySelector('#scroll-container'),
            smooth: true, multiplier: 0.9, lerp: 0.07,
            smartphone: { smooth: false }, tablet: { smooth: false }
        });
        window.addEventListener('load', () => locoScroll.update());

        // Hamburger menu
        const hamburger = document.getElementById('hamburgerBtn');
        const navLinks = document.getElementById('navLinks');
        if (hamburger) {
            hamburger.addEventListener('click', () => {
                navLinks.classList.toggle('open');
            });
        }
    </script>
</body>
</html>